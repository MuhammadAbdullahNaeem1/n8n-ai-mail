# --- Copy to .env and fill in. Never commit .env. ---

# n8n
# Generate with: openssl rand -hex 24
N8N_ENCRYPTION_KEY=
N8N_HOST=localhost
WEBHOOK_URL=http://localhost:5678/
TZ=Asia/Karachi

# Postgres (defaults are fine for local dev)
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n
POSTGRES_DB=n8n

# LLM — any OpenAI-compatible endpoint works.
# Examples:
#   OpenAI:      https://api.openai.com/v1
#   Ollama:      https://ollama.com/v1  (cloud) or http://host.docker.internal:11434/v1 (local)
#   Zhipu/GLM:   https://open.bigmodel.cn/api/paas/v4
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL_CLASSIFY=
LLM_MODEL_DRAFT=

# Embeddings (for Qdrant RAG). Must be reachable at LLM_BASE_URL
# or override with a separate endpoint in the workflow credential.
EMBEDDING_MODEL=

# Optional: Slack incoming webhook for urgent-email alerts. Leave empty to disable.
SLACK_WEBHOOK_URL=

# --- Gmail variant (workflow 03) ---
# Which messages the workflow is allowed to read. Keep this narrow on a real inbox.
#   is:unread newer_than:1d     → recent unread only (default)
#   label:ai-triage             → safest: only mail YOU label 'ai-triage'
GMAIL_QUERY=is:unread newer_than:1d
# Max messages per run. Each costs ~3 API calls, so keep it small on free tier.
GMAIL_FETCH_LIMIT=5
