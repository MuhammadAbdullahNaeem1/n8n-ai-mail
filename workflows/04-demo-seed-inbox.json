      "id": "seed-parse",
      "name": "Parse Seed Inbox",
      "type": "n8n-nodes-base.extractFromFile",
      "typeVersion": 1,
      "position": [
        220,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "// Turn each seed email into an RFC-822 message Gmail can insert directly.\n// insert (not send) means the mail keeps its original From: header, so the\n// demo inbox looks like real customer mail rather than 24 notes to yourself.\nconst byName = {};\nfor (const l of ($('Get Labels (final)').first().json.labels || [])) byName[l.name] = l.id;\nconst me = $('Get Profile').first().json.emailAddress;\n\n// Seed file may arrive as a bare array or wrapped under .data\nconst emails = [];\nfor (const item of $input.all()) {\n  const d = item.json;\n  if (Array.isArray(d)) emails.push(...d);\n  else if (Array.isArray(d.data)) emails.push(...d.data);\n  else emails.push(d);\n}\n\nconst n = parseInt($env.DEMO_SEED_COUNT || '0', 10);\n// DEMO_SEED_COUNT=-1 -> labels-only pass. Lets you add or rename labels\n// without injecting a second copy of the 24 seed emails.\nif (n < 0) return [];\nconst list = n > 0 ? emails.slice(0, n) : emails;\n\nconst triage = byName['ai-triage'];\nconst out = [];\nfor (const e of list) {\n  const local = String(e.from || 'unknown@example.com').split('@')[0];\n  const display = local.replace(/[._-]+/g, ' ').replace(/\\b\\w/g, c => c.toUpperCase());\n  const date = new Date(e.received_at || Date.now()).toUTCString();\n  const headers = [\n    'From: ' + display + ' <' + e.from + '>',\n    'To: ' + me,\n    'Subject: ' + String(e.subject || '(no subject)'),\n    'Date: ' + date,\n    'MIME-Version: 1.0',\n    'Content-Type: text/plain; charset=\"UTF-8\"',\n    'Content-Transfer-Encoding: 7bit',\n  ].join('\\r\\n');\n  const raw = headers + '\\r\\n\\r\\n' + String(e.body || '');\n  const b64 = Buffer.from(raw, 'utf8').toString('base64')\n    .replace(/\\+/g, '-').replace(/\\//g, '_').replace(/=+$/, '');\n  const labelIds = ['INBOX', 'UNREAD'];\n  if (triage) labelIds.push(triage);\n  out.push({ json: { seed_id: e.id, subject: e.subject, from: e.from, raw: b64, labelIds } });\n}\nreturn out;"
      },
      "id": "seed-build",
      "name": "Build Raw Messages",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        320
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://gmail.googleapis.com/gmail/v1/users/me/messages?internalDateSource=dateHeader",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "gmailOAuth2",
        "options": {},
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ raw: $json.raw, labelIds: $json.labelIds }) }}"
      },
      "id": "seed-insert",
      "name": "Insert Message",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
