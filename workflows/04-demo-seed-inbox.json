    {
      "parameters": {
        "jsCode": "// The full label taxonomy the demo needs. Creating \"AI/Sales\" also\n// creates the \"AI\" parent automatically on Gmail's side.\nconst LABELS = [\n  \"ai-triage\",\n  \"AI/Sales\",\n  \"AI/Support\",\n  \"AI/Billing\",\n  \"AI/Cancellation\",\n  \"AI/Partnership\",\n  \"AI/Feedback\",\n  \"AI/Newsletter\",\n  \"AI/Notification\",\n  \"AI/Cold Outreach\",\n  \"AI/Spam\",\n  \"AI/Other\",\n  \"AI/Urgent\",\n  \"AI/Needs Review\",\n  \"AI/No Reply Needed\"\n];\nreturn LABELS.map(name => ({ json: {\n  name,\n  labelListVisibility: 'labelShow',\n  messageListVisibility: 'show',\n} }));"
      },
      "id": "seed-plan",
      "name": "Plan Labels",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        0
      ]
    },
    {
